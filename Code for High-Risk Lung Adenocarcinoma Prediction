# ==================== 可视化参数配置 ====================
WINDOW_WIDTH = 1500
WINDOW_LEVEL = -500

# 颜色定义
MASK_COLOR = (1, 0, 0)           # 红色
HIGH_DENSITY_COLOR = (1, 0, 0)   # 红色
LOW_DENSITY_COLOR = (0, 0, 1)    # 蓝色
HIGH_ENTROPY_COLOR = (1, 1, 0)   # 黄色
LOW_ENTROPY_COLOR = (0, 1, 0)    # 绿色

HABITAT_COLORS = {
    1: (1, 1, 0),  # 高密度&高熵 - 黄色
    2: (1, 0, 0),  # 高密度&低熵 - 红色
    3: (0, 1, 0),  # 低密度&高熵 - 绿色
    4: (0, 0, 1)   # 低密度&低熵 - 蓝色
}

# 透明度
MASK_ALPHA_SEMI = 0.5
DENSITY_ALPHA_SEMI = 0.5
ENTROPY_ALPHA_SEMI = 0.5
FUSED_ALPHA_SEMI = 0.5

# 裁剪扩展因子
CROP_EXPAND_FACTOR = 3
TARGET_SIZE = 256


# ==================== Core Pipeline ====================
class RadiomicsPipeline:
    """
    Habitat imaging pipeline for high-risk LUAD prediction.
    Steps: resample, entropy calculation, threshold masks, fusion, volume stats, prediction.
    """

    def __init__(self, ct_path, mask_path, output_dir,
                 density_threshold=-405.0, entropy_threshold=4.204,
                 label2_threshold=172.0, new_spacing=(1.0, 1.0, 1.0)):
        self.ct_path = ct_path
        self.mask_path = mask_path
        self.output_dir = output_dir
        self.DENSITY_THRESHOLD = density_threshold
        self.ENTROPY_THRESHOLD = entropy_threshold
        self.LABEL2_VOLUME_THRESHOLD = label2_threshold
        self.NEW_SPACING = new_spacing

        self.case_name = os.path.basename(ct_path).replace('.nii.gz', '')

        # Output subdirectories
        self.RESAMPLE_DIR = os.path.join(output_dir, self.case_name, "1_resampled")
        self.ENTROPY_DIR = os.path.join(output_dir, self.case_name, "2_entropy_maps")
        self.DERIVED_MASKS_DIR = os.path.join(output_dir, self.case_name, "3_threshold_masks")
        self.FUSION_DIR = os.path.join(output_dir, self.case_name, "4_fusion_masks")
        # 修改顺序：5_visualizations 存放可视化图像，6_prediction_results 存放预测结果
        self.RESULTS_DIR = os.path.join(output_dir, self.case_name, "5_visualizations")
        self.VIZ_DIR = os.path.join(output_dir, self.case_name, "6_prediction_results")
        for d in [self.RESAMPLE_DIR, self.ENTROPY_DIR, self.DERIVED_MASKS_DIR,
                  self.FUSION_DIR, self.RESULTS_DIR, self.VIZ_DIR]:
            os.makedirs(d, exist_ok=True)

        self.log_callback = None
        self.viz_paths = {}  # 存储所有生成图像的路径

    def set_log_callback(self, callback):
        self.log_callback = callback

    def log(self, msg):
        if self.log_callback:
            self.log_callback(msg)
        else:
            print(msg)

    # ---------- Image I/O ----------
    def read_image(self, path):
        return sitk.ReadImage(path)

    def write_image(self, img, path):
        sitk.WriteImage(img, path, useCompression=True)

    # ---------- Resampling ----------
    def resample_image(self, img, new_spacing, is_mask=False):
        original_spacing = img.GetSpacing()
        original_size = img.GetSize()
        new_size = [
            int(round(original_size[i] * original_spacing[i] / new_spacing[i]))
            for i in range(3)
        ]
        resampler = sitk.ResampleImageFilter()
        resampler.SetOutputSpacing(new_spacing)
        resampler.SetSize(new_size)
        resampler.SetOutputDirection(img.GetDirection())
        resampler.SetOutputOrigin(img.GetOrigin())
        resampler.SetTransform(sitk.Transform())
        resampler.SetInterpolator(sitk.sitkNearestNeighbor if is_mask else sitk.sitkLinear)
        return resampler.Execute(img)

    # ---------- Step 1: Resample ----------
    def step1_resample(self):
        out_ct = os.path.join(self.RESAMPLE_DIR, f"{self.case_name}_resample.nii.gz")
        out_mask = os.path.join(self.RESAMPLE_DIR, f"{self.case_name}_resample_mask.nii.gz")

        ct_img = self.read_image(self.ct_path)
        mask_img = self.read_image(self.mask_path)

        ct_resampled = self.resample_image(ct_img, self.NEW_SPACING, is_mask=False)
        mask_resampled = self.resample_image(mask_img, self.NEW_SPACING, is_mask=True)

        self.write_image(ct_resampled, out_ct)
        self.write_image(mask_resampled, out_mask)
        self.log(f"  [1/6] Resampling done: {os.path.basename(out_ct)}")
        return out_ct, out_mask

    # ---------- Step 2: Entropy ----------
    def calculate_entropy_3x3x3(self, data):
        def entropy_calculator(values):
            values = values.reshape(3, 3, 3)
            values = values[~np.isnan(values)]
            if len(values) == 0:
                return np.nan
            hist, _ = np.histogram(values, bins=32, density=True)
            prob = hist / hist.sum() if hist.sum() > 0 else hist
            prob = prob[prob > 0]
            return -np.sum(prob * np.log2(prob))
        return generic_filter(data, entropy_calculator, size=3, mode='constant', cval=np.nan)

    def step2_compute_entropy(self, ct_resampled_path):
        ct_img = self.read_image(ct_resampled_path)
        ct_arr = sitk.GetArrayFromImage(ct_img).astype(np.float32)
        self.log("  [2/6] Computing local entropy (3x3x3)...")
        entropy_arr = self.calculate_entropy_3x3x3(ct_arr)
        entropy_arr = np.nan_to_num(entropy_arr, nan=0.0)
        entropy_img = sitk.GetImageFromArray(entropy_arr)
        entropy_img.CopyInformation(ct_img)
        out_path = os.path.join(self.ENTROPY_DIR, f"{self.case_name}_resample_entropy.nii.gz")
        self.write_image(entropy_img, out_path)
        self.log("  [2/6] Entropy map saved.")
        return out_path, entropy_arr

    # ---------- Step 3: Threshold masks ----------
    def step3_generate_threshold_masks(self, ct_resampled_path, mask_resampled_path, entropy_path):
        ct_img = self.read_image(ct_resampled_path)
        mask_img = self.read_image(mask_resampled_path)
        entropy_img = self.read_image(entropy_path)

        ct_arr = sitk.GetArrayFromImage(ct_img)
        mask_arr = sitk.GetArrayFromImage(mask_img).astype(bool)
        entropy_arr = sitk.GetArrayFromImage(entropy_img)

        high_density = np.zeros_like(mask_arr, dtype=np.uint8)
        low_density = np.zeros_like(mask_arr, dtype=np.uint8)
        high_entropy = np.zeros_like(mask_arr, dtype=np.uint8)
        low_entropy = np.zeros_like(mask_arr, dtype=np.uint8)

        region_mask = mask_arr > 0
        high_density[region_mask] = (ct_arr[region_mask] >= self.DENSITY_THRESHOLD).astype(np.uint8)
        low_density[region_mask] = (ct_arr[region_mask] < self.DENSITY_THRESHOLD).astype(np.uint8)
        high_entropy[region_mask] = (entropy_arr[region_mask] >= self.ENTROPY_THRESHOLD).astype(np.uint8)
        low_entropy[region_mask] = (entropy_arr[region_mask] < self.ENTROPY_THRESHOLD).astype(np.uint8)

        def save_mask(arr, suffix):
            img = sitk.GetImageFromArray(arr)
            img.CopyInformation(mask_img)
            path = os.path.join(self.DERIVED_MASKS_DIR, f"{self.case_name}_{suffix}.nii.gz")
            self.write_image(img, path)
            return path

        paths = {
            'high_density': save_mask(high_density, 'high_density_mask'),
            'low_density': save_mask(low_density, 'low_density_mask'),
            'high_entropy': save_mask(high_entropy, 'high_entropy_mask'),
            'low_entropy': save_mask(low_entropy, 'low_entropy_mask')
        }
        self.log("  [3/6] 4 threshold masks generated.")
        return paths, ct_arr, mask_arr, entropy_arr, mask_img

    # ---------- Step 4: Fuse into 4-label image ----------
    def step4_fuse_masks(self, threshold_paths, mask_img):
        high_density = sitk.GetArrayFromImage(self.read_image(threshold_paths['high_density'])).astype(bool)
        low_density = sitk.GetArrayFromImage(self.read_image(threshold_paths['low_density'])).astype(bool)
        high_entropy = sitk.GetArrayFromImage(self.read_image(threshold_paths['high_entropy'])).astype(bool)
        low_entropy = sitk.GetArrayFromImage(self.read_image(threshold_paths['low_entropy'])).astype(bool)

        fused = np.zeros_like(high_density, dtype=np.uint8)
        fused[high_density & high_entropy] = 1   # Label 1: high density & high entropy
        fused[high_density & low_entropy]  = 2   # Label 2: high density & low entropy
        fused[low_density  & high_entropy] = 3   # Label 3: low density & high entropy
        fused[low_density  & low_entropy]  = 4   # Label 4: low density & low entropy

        fused_img = sitk.GetImageFromArray(fused)
        fused_img.CopyInformation(mask_img)
        out_path = os.path.join(self.FUSION_DIR, f"{self.case_name}_fused_labels.nii.gz")
        self.write_image(fused_img, out_path)
        self.log("  [4/6] Fused label image saved.")
        return fused, out_path

    # ---------- Step 5: Volume statistics ----------
    def step5_compute_volumes(self, fused_arr, mask_arr, voxel_volume=1.0):
        total_voxels = np.sum(mask_arr > 0)
        if total_voxels == 0:
            return None
        volumes = {}
        for label in [1, 2, 3, 4]:
            count = np.sum(fused_arr == label)
            vol = count * voxel_volume
            ratio = count / total_voxels if total_voxels > 0 else 0
            volumes[label] = {'count': count, 'volume_mm3': vol, 'ratio': ratio}
        return volumes

    # ---------- Step 6: Prediction (based on label 2 volume) ----------
    def step6_predict(self, volumes):
        label2_vol = volumes.get(2, {}).get('volume_mm3', 0)
        return 1 if label2_vol > self.LABEL2_VOLUME_THRESHOLD else 0

    # ---------- 可视化辅助函数 ----------
    def find_max_slice(self, mask_arr):
        try:
            slices = []
            for z in range(mask_arr.shape[0]):
                count = np.sum(mask_arr[z] > 0)
                if count > 0:
                    slices.append((z, count))
            if not slices:
                return mask_arr.shape[0] // 2
            return max(slices, key=lambda x: x[1])[0]
        except Exception as e:
            self.log(f"    find_max_slice warning: {e}")
            return 0

    def get_crop_window(self, mask_slice, expand_factor=CROP_EXPAND_FACTOR):
        try:
            coords = np.argwhere(mask_slice)
            if len(coords) == 0:
                return 0, mask_slice.shape[0], 0, mask_slice.shape[1]
            y_min, x_min = coords.min(axis=0)
            y_max, x_max = coords.max(axis=0)
            center_y = (y_min + y_max) // 2
            center_x = (x_min + x_max) // 2
            height = y_max - y_min + 1
            width = x_max - x_min + 1
            crop_height = int(height * expand_factor)
            crop_width = int(width * expand_factor)
            y_start = max(0, center_y - crop_height // 2)
            y_end = min(mask_slice.shape[0], y_start + crop_height)
            x_start = max(0, center_x - crop_width // 2)
            x_end = min(mask_slice.shape[1], x_start + crop_width)
            if y_end - y_start < crop_height:
                y_start = max(0, y_end - crop_height)
            if x_end - x_start < crop_width:
                x_start = max(0, x_end - crop_width)
            return y_start, y_end, x_start, x_end
        except Exception as e:
            self.log(f"    get_crop_window warning: {e}")
            return 0, mask_slice.shape[0], 0, mask_slice.shape[1]

    def apply_window(self, ct_slice, width=WINDOW_WIDTH, level=WINDOW_LEVEL):
        lower = level - width / 2
        upper = level + width / 2
        windowed = (ct_slice - lower) / (upper - lower)
        return np.clip(windowed, 0, 1)

    def resize_2d(self, img, target_size=TARGET_SIZE, order=0):
        h, w = img.shape
        if h == target_size and w == target_size:
            return img
        return resize(img, (target_size, target_size), order=order, preserve_range=True, anti_aliasing=False)

    def add_legend_to_axes(self, ax, legend_items, loc='upper left', fontsize=10):
        """在给定的 axes 上添加图例（小色块+文字）"""
        try:
            x_start, y_start = 0.02, 0.98
            step = 0.08  # 增大行间距
            for i, (color, label) in enumerate(legend_items):
                rect = Rectangle((x_start, y_start - i*step - 0.04), 0.04, 0.04,
                                 transform=ax.transAxes, facecolor=color, edgecolor='black', linewidth=0.5)
                ax.add_patch(rect)
                ax.text(x_start + 0.05, y_start - i*step - 0.02, label,
                        transform=ax.transAxes, fontsize=fontsize, verticalalignment='center',
                        bbox=dict(facecolor='white', alpha=0.7, edgecolor='none', pad=1))
        except Exception as e:
            self.log(f"      add_legend_to_axes warning: {e}")

    # ---------- 生成所有图像 ----------
    def generate_all_visualizations(self, ct_resampled_path, mask_resampled_path,
                                     entropy_path, threshold_paths, fused_arr, mask_arr, entropy_arr, volumes, prediction):
        try:
            self.log("  Generating visualizations...")
            ct_img = self.read_image(ct_resampled_path)
            mask_img = self.read_image(mask_resampled_path)
            entropy_img = self.read_image(entropy_path)

            ct_arr = sitk.GetArrayFromImage(ct_img)
            mask_arr_bool = sitk.GetArrayFromImage(mask_img).astype(bool)
            entropy_arr_full = sitk.GetArrayFromImage(entropy_img)

            high_density = sitk.GetArrayFromImage(self.read_image(threshold_paths['high_density'])).astype(bool)
            low_density = sitk.GetArrayFromImage(self.read_image(threshold_paths['low_density'])).astype(bool)
            high_entropy = sitk.GetArrayFromImage(self.read_image(threshold_paths['high_entropy'])).astype(bool)
            low_entropy = sitk.GetArrayFromImage(self.read_image(threshold_paths['low_entropy'])).astype(bool)

            max_slice_idx = self.find_max_slice(mask_arr_bool)
            self.log(f"    Max slice index: {max_slice_idx}")

            # 提取该层面的数据
            ct_slice = ct_arr[max_slice_idx]
            mask_slice = mask_arr_bool[max_slice_idx]
            entropy_slice = entropy_arr_full[max_slice_idx]
            high_density_slice = high_density[max_slice_idx]
            low_density_slice = low_density[max_slice_idx]
            high_entropy_slice = high_entropy[max_slice_idx]
            low_entropy_slice = low_entropy[max_slice_idx]
            fused_slice = fused_arr[max_slice_idx]

            # 裁剪
            y_start, y_end, x_start, x_end = self.get_crop_window(mask_slice)
            ct_cropped = ct_slice[y_start:y_end, x_start:x_end]
            mask_cropped = mask_slice[y_start:y_end, x_start:x_end]
            entropy_cropped = entropy_slice[y_start:y_end, x_start:x_end]
            high_density_cropped = high_density_slice[y_start:y_end, x_start:x_end]
            low_density_cropped = low_density_slice[y_start:y_end, x_start:x_end]
            high_entropy_cropped = high_entropy_slice[y_start:y_end, x_start:x_end]
            low_entropy_cropped = low_entropy_slice[y_start:y_end, x_start:x_end]
            fused_cropped = fused_slice[y_start:y_end, x_start:x_end]

            # 缩放到统一尺寸
            ct_resized = self.resize_2d(ct_cropped, TARGET_SIZE, order=1)
            mask_resized = self.resize_2d(mask_cropped.astype(float), TARGET_SIZE, order=0) > 0.5
            entropy_resized = self.resize_2d(entropy_cropped, TARGET_SIZE, order=1)
            high_density_resized = self.resize_2d(high_density_cropped.astype(float), TARGET_SIZE, order=0) > 0.5
            low_density_resized = self.resize_2d(low_density_cropped.astype(float), TARGET_SIZE, order=0) > 0.5
            high_entropy_resized = self.resize_2d(high_entropy_cropped.astype(float), TARGET_SIZE, order=0) > 0.5
            low_entropy_resized = self.resize_2d(low_entropy_cropped.astype(float), TARGET_SIZE, order=0) > 0.5
            fused_resized = self.resize_2d(fused_cropped.astype(float), TARGET_SIZE, order=0).astype(int)

            # 应用肺窗
            ct_norm = self.apply_window(ct_resized)
            rgb_ct = np.stack([ct_norm, ct_norm, ct_norm], axis=2)

            # 熵图灰度
            rgb_entropy = np.stack([entropy_resized, entropy_resized, entropy_resized], axis=2)
            if np.max(rgb_entropy) > 0:
                rgb_entropy = rgb_entropy / np.max(rgb_entropy)

            # Habitat labels 图
            rgb_habitat = rgb_ct.copy()
            for label in [1, 2, 3, 4]:
                mask_label = (fused_resized == label)
                if np.any(mask_label):
                    rgb_habitat[mask_label] = (1 - FUSED_ALPHA_SEMI) * rgb_habitat[mask_label] + FUSED_ALPHA_SEMI * np.array(HABITAT_COLORS[label])

            # Solid component 图 (只显示 Label2)
            rgb_solid = rgb_ct.copy()
            mask_label2 = (fused_resized == 2)
            if np.any(mask_label2):
                rgb_solid[mask_label2] = (1 - FUSED_ALPHA_SEMI) * rgb_solid[mask_label2] + FUSED_ALPHA_SEMI * np.array(HABITAT_COLORS[2])

            # 生成复合图（2行2列：CT map, Entropy map, Habitat labels, Solid component）
            images = [rgb_ct, rgb_entropy, rgb_habitat, rgb_solid]
            titles = ["CT map", "Entropy map", "Habitat labels", "Solid component"]
            self.generate_composite_figure(
                images, titles,
                "07_composite.png", "Habitat Imaging Visualizations",
                volumes, prediction, rgb_solid  # 传递额外信息用于 Solid component 子图
            )

            # 同时保存单个图像（可选，用于完整输出）
            self.save_single_image(rgb_ct, "01_ct_map.png", "CT map")
            self.save_single_image(rgb_entropy, "02_entropy_map.png", "Entropy map")
            self.save_single_image(rgb_habitat, "03_habitat_labels.png", "Habitat labels",
                                   legend=[(HABITAT_COLORS[1], "High density & High entropy"),
                                           (HABITAT_COLORS[2], "High density & Low entropy"),
                                           (HABITAT_COLORS[3], "Low density & High entropy"),
                                           (HABITAT_COLORS[4], "Low density & Low entropy")])
            self.save_single_image(rgb_solid, "04_solid_component.png", "Solid component",
                                   legend=[(HABITAT_COLORS[2], "High density & Low entropy")])

            return self.viz_paths
        except Exception as e:
            self.log(f"  Error generating visualizations: {e}")
            traceback.print_exc()
            return {}

    def save_single_image(self, rgb_array, filename, title, legend=None):
        """保存单个图像，可带图例"""
        try:
            path = os.path.join(self.VIZ_DIR, filename)
            fig = Figure(figsize=(6, 6))
            fig.patch.set_facecolor('white')
            ax = fig.add_subplot(111)
            ax.imshow(rgb_array)
            ax.set_title(title, fontsize=12, fontweight='bold')  # 增大标题字体
            ax.axis('off')
            if legend:
                self.add_legend_to_axes(ax, legend, fontsize=10)  # 图例字体
            fig.savefig(path, dpi=150, bbox_inches='tight', facecolor='white')
            plt.close(fig)
            key = filename.replace('.png', '').replace('_', '')
            self.viz_paths[key] = path
        except Exception as e:
            self.log(f"    Error saving {filename}: {e}")

    def generate_composite_figure(self, images, titles, filename, suptitle, volumes, prediction, solid_img):
        """生成复合图，2行2列，每个子图内嵌图例，并在 Solid component 子图上标注体积和预测"""
        try:    
            # 修正文件名为 05_composite.png
            filename = "05_composite.png"
            path = os.path.join(self.VIZ_DIR, filename)
        
            # 增大图形尺寸，让子图更大
            fig = Figure(figsize=(14, 12))
            fig.patch.set_facecolor('white')
        
            # 精细调整子图布局：减小外边距，压缩子图间距
            # left, right, bottom, top 为子图区域相对于图形的边距
            # hspace, wspace 为子图之间的间距（占子图平均尺寸的比例）
            fig.subplots_adjust(left=0.06, right=0.94, bottom=0.06, top=0.94, hspace=0.1, wspace=-0.2)
        
            for i, (img, title) in enumerate(zip(images, titles)):
                ax = fig.add_subplot(2, 2, i+1)
                ax.imshow(img)
                ax.set_title(title, fontsize=14, fontweight='bold')
                ax.axis('off')
            
                # 根据子图标题添加相应图例（字体略大）
                if title == "CT map":
                    pass
                elif title == "Entropy map":
                    pass
                elif title == "Habitat labels":
                    self.add_legend_to_axes(ax, [(HABITAT_COLORS[1], "High density & High entropy"),
                                                  (HABITAT_COLORS[2], "High density & Low entropy"),
                                                  (HABITAT_COLORS[3], "Low density & High entropy"),
                                                  (HABITAT_COLORS[4], "Low density & Low entropy")],
                                            fontsize=10)
                elif title == "Solid component":
                    self.add_legend_to_axes(ax, [(HABITAT_COLORS[2], "High density & Low entropy")],
                                            fontsize=10)
                    # 标注体积和预测，字体加大
                    label2_vol = volumes[2]['volume_mm3']
                    pred_text = "High-risk" if prediction == 1 else "Low-risk"
                    vol_text = f"Volume = {label2_vol:.1f} mm³\nPrediction = {pred_text}"
                    ax.text(0.5, 0.05, vol_text, transform=ax.transAxes, fontsize=12,
                            ha='center', va='bottom', bbox=dict(facecolor='white', alpha=0.8, edgecolor='black'))

            fig.suptitle(suptitle, fontsize=18, fontweight='bold', y=0.98)  # y 微调总标题位置
            fig.savefig(path, dpi=150, bbox_inches='tight', facecolor='white')
            plt.close(fig)
            self.viz_paths['composite'] = path
        except Exception as e:
            self.log(f"    Error saving composite figure: {e}")

            # ---------- Run full pipeline ----------
    def run(self):
        try:
            self.log(f"\nProcessing case: {self.case_name}")
            ct_resampled, mask_resampled = self.step1_resample()
            entropy_path, entropy_arr = self.step2_compute_entropy(ct_resampled)
            threshold_paths, ct_arr, mask_arr, entropy_arr_full, mask_img = self.step3_generate_threshold_masks(
                ct_resampled, mask_resampled, entropy_path)
            fused_arr, _ = self.step4_fuse_masks(threshold_paths, mask_img)
            volumes = self.step5_compute_volumes(fused_arr, mask_arr, voxel_volume=1.0)

            if volumes is None:
                self.log("  [Warning] Mask region empty, skipping.")
                return None

            self.log("  [5/6] Volume statistics:")
            desc = {1: "High density & High entropy",
                    2: "High density & Low entropy",
                    3: "Low density & High entropy",
                    4: "Low density & Low entropy"}
            for lbl in [1,2,3,4]:
                self.log(f"      Label {lbl} ({desc[lbl]}): volume = {volumes[lbl]['volume_mm3']:.2f} mm³, ratio = {volumes[lbl]['ratio']:.4f}")

            prediction = self.step6_predict(volumes)
            self.log(f"  [6/6] Prediction: Label 2 volume > {self.LABEL2_VOLUME_THRESHOLD} mm³? -> {prediction} (1=High-risk, 0=Low-risk)")

            # 生成可视化
            viz_paths = self.generate_all_visualizations(
                ct_resampled, mask_resampled, entropy_path,
                threshold_paths, fused_arr, mask_arr, entropy_arr, volumes, prediction
            )

            result = {
                'case': self.case_name,
                'label1_HighDensity_HighEntropy_vol_mm3': volumes[1]['volume_mm3'],
                'label2_HighDensity_LowEntropy_vol_mm3': volumes[2]['volume_mm3'],
                'label3_LowDensity_HighEntropy_vol_mm3': volumes[3]['volume_mm3'],
                'label4_LowDensity_LowEntropy_vol_mm3': volumes[4]['volume_mm3'],
                'label1_ratio': volumes[1]['ratio'],
                'label2_ratio': volumes[2]['ratio'],
                'label3_ratio': volumes[3]['ratio'],
                'label4_ratio': volumes[4]['ratio'],
                'prediction': prediction,
                'viz_paths': viz_paths
            }

            # Save CSV
            df = pd.DataFrame([result])
            csv_path = os.path.join(self.RESULTS_DIR, f"{self.case_name}_prediction.csv")
            df.to_csv(csv_path, index=False)
            self.log(f"Results saved to: {csv_path}")

            return result
        except Exception as e:
            self.log(f"Error in pipeline: {str(e)}")
            traceback.print_exc()
            return None


# ==================== Batch Processing Thread ====================
class BatchProcessingThread(QThread):
    progress_update = pyqtSignal(str, int)
    case_completed = pyqtSignal(dict)
    batch_finished = pyqtSignal(list)
    error_occurred = pyqtSignal(str, str)

    def __init__(self, file_pairs, output_dir, params):
        super().__init__()
        self.file_pairs = file_pairs
        self.output_dir = output_dir
        self.params = params
        self._is_running = True

    def stop(self):
        self._is_running = False

    def run(self):
        all_results = []
        total = len(self.file_pairs)
        for idx, (ct_path, mask_path, case_name) in enumerate(self.file_pairs):
            if not self._is_running:
                break
            self.progress_update.emit(f"Processing {idx+1}/{total}: {case_name}", int((idx/total)*100))
            try:
                pipeline = RadiomicsPipeline(
                    ct_path=ct_path,
                    mask_path=mask_path,
                    output_dir=self.output_dir,
                    density_threshold=self.params['density_threshold'],
                    entropy_threshold=self.params['entropy_threshold'],
                    label2_threshold=self.params['label2_threshold']
                )
                result = pipeline.run()
                if result:
                    all_results.append(result)
                    self.case_completed.emit(result)
            except Exception as e:
                self.error_occurred.emit(case_name, str(e))
        self.batch_finished.emit(all_results)


