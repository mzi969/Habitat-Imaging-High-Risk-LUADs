    def scan_batch_directory(self):
        dir_path = self.batch_dir_edit.text().strip()
        if not dir_path or not os.path.isdir(dir_path):
            QMessageBox.warning(self, "Warning", "Please select a valid input directory first!")
            return

        self.file_list.clear()
        self.file_pairs = []

        all_files = glob.glob(os.path.join(dir_path, "*.nii.gz"))
        ct_files = [f for f in all_files if not f.endswith('_mask.nii.gz')]

        for ct in ct_files:
            base = os.path.basename(ct).replace('.nii.gz', '')
            mask_candidate = os.path.join(dir_path, f"{base}_mask.nii.gz")
            if os.path.exists(mask_candidate):
                self.file_pairs.append((ct, mask_candidate, base))
                self.file_list.addItem(f"✓ {base}: CT={os.path.basename(ct)}, Mask={os.path.basename(mask_candidate)}")
            else:
                self.file_list.addItem(f"✗ {base}: No matching mask found")

        if self.file_pairs:
            self.file_list.addItem(f"Found {len(self.file_pairs)} valid case(s).")
            self.check_inputs()
        else:
            self.file_list.addItem("No valid file pairs found.")

    def check_inputs(self):
        if self.single_mode_radio.isChecked():
            valid = bool(self.ct_edit.text().strip()) and bool(self.mask_edit.text().strip())
        else:
            valid = bool(self.batch_dir_edit.text().strip()) and len(self.file_pairs) > 0
        self.start_btn.setEnabled(valid)

    # ---------- Processing start/stop ----------
    def start_processing(self):
        output_dir = self.out_edit.text().strip()
        if not output_dir:
            output_dir = str(Path.home() / "HabitatLUAD_Output")
            self.out_edit.setText(output_dir)
        os.makedirs(output_dir, exist_ok=True)

        try:
            density_thresh = float(self.density_edit.text())
            entropy_thresh = float(self.entropy_edit.text())
            label2_thresh = float(self.label2_edit.text())
        except ValueError:
            QMessageBox.critical(self, "Error", "All thresholds must be valid numbers!")
            return

        self.log_text.clear()
        self.log("Starting processing...")
        self.start_btn.setEnabled(False)
        self.stop_btn.setEnabled(True)
        self.progress_bar.setValue(0)

        params = {
            'density_threshold': density_thresh,
            'entropy_threshold': entropy_thresh,
            'label2_threshold': label2_thresh
        }

        if self.single_mode_radio.isChecked():
            ct_path = self.ct_edit.text()
            mask_path = self.mask_edit.text()
            self.run_single_case(ct_path, mask_path, output_dir, params)
        else:
            self.run_batch_processing(output_dir, params)

    def run_single_case(self, ct_path, mask_path, output_dir, params):
        self.pipeline = RadiomicsPipeline(
            ct_path=ct_path,
            mask_path=mask_path,
            output_dir=output_dir,
            density_threshold=params['density_threshold'],
            entropy_threshold=params['entropy_threshold'],
            label2_threshold=params['label2_threshold']
        )
        self.pipeline.set_log_callback(self.log)

        def target():
            try:
                result = self.pipeline.run()
                self.single_finished(result)
            except Exception as e:
                self.log(f"Processing failed: {e}")
                self.reset_ui()

        self.thread = threading.Thread(target=target)
        self.thread.daemon = True
        self.thread.start()

        # Simulate progress
        self.progress = 0
        self.progress_timer = QTimer()
        self.progress_timer.timeout.connect(lambda: self.progress_bar.setValue(min(self.progress, 99)))
        self.progress_timer.start(200)

    def run_batch_processing(self, output_dir, params):
        self.batch_thread = BatchProcessingThread(self.file_pairs, output_dir, params)
        self.batch_thread.progress_update.connect(self.update_batch_progress)
        self.batch_thread.case_completed.connect(self.add_batch_result)
        self.batch_thread.batch_finished.connect(self.batch_finished)
        self.batch_thread.error_occurred.connect(self.batch_error)
        self.batch_thread.start()

    def stop_processing(self):
        if hasattr(self, 'thread') and self.thread.is_alive():
            self.log("Stop requested. The current operation may finish before stopping.")
        if hasattr(self, 'batch_thread') and self.batch_thread.isRunning():
            self.batch_thread.stop()
        self.reset_ui()

    # ---------- Single case callbacks ----------
    def single_finished(self, result):
        self.progress_timer.stop()
        self.progress_bar.setValue(100)
        if result:
            self.current_results = [result]
            self.update_single_table(result)
            self.update_composite_image(result)
            self.export_csv_btn.setEnabled(True)
            self.export_excel_btn.setEnabled(True)
            self.save_viz_btn.setEnabled(True)
            self.log("✅ Processing completed successfully!")
            self.tabs.setCurrentIndex(1)  # switch to results tab
        else:
            self.log("Processing finished but no result produced.")
        self.reset_ui()

    def update_single_table(self, result):
        self.single_table.setRowCount(1)
        items = [
            result['case'],
            f"{result['label1_HighDensity_HighEntropy_vol_mm3']:.2f}",
            f"{result['label2_HighDensity_LowEntropy_vol_mm3']:.2f}",
            f"{result['label3_LowDensity_HighEntropy_vol_mm3']:.2f}",
            f"{result['label4_LowDensity_LowEntropy_vol_mm3']:.2f}",
            "High-risk" if result['prediction'] == 1 else "Low-risk"
        ]
        for col, text in enumerate(items):
            item = QTableWidgetItem(text)
            item.setTextAlignment(Qt.AlignCenter)
            # 为第2列（Label2 Volume）设置背景色，与预测列相同
            if col == 2:  # Label2 column
                if result['prediction'] == 1:
                    item.setBackground(QColor(255, 200, 200))
                    item.setForeground(QColor(200, 0, 0))
                else:
                    item.setBackground(QColor(200, 255, 200))
                    item.setForeground(QColor(0, 128, 0))
            if col == 5:  # prediction column
                if result['prediction'] == 1:
                    item.setBackground(QColor(255, 200, 200))
                    item.setForeground(QColor(200, 0, 0))
                else:
                    item.setBackground(QColor(200, 255, 200))
                    item.setForeground(QColor(0, 128, 0))
            self.single_table.setItem(0, col, item)

    def update_composite_image(self, result):
        viz_paths = result.get('viz_paths', {})
        composite_path = viz_paths.get('composite')
        if composite_path and os.path.exists(composite_path):
            pixmap = QPixmap(composite_path)
            scaled = pixmap.scaled(900, 600, Qt.KeepAspectRatio, Qt.SmoothTransformation)
            self.composite_label.setPixmap(scaled)
            self.composite_label.setText("")

    def save_visualizations(self):
        if not self.current_results:
            return
        result = self.current_results[0]
        viz_paths = result.get('viz_paths', {})
        if not viz_paths:
            QMessageBox.warning(self, "Warning", "No visualizations to save!")
            return
        save_dir = QFileDialog.getExistingDirectory(self, "Select Directory to Save Visualizations")
        if not save_dir:
            return
        import shutil
        saved = []
        for key, path in viz_paths.items():
            if os.path.exists(path):
                dest = os.path.join(save_dir, f"{result['case']}_{key}.png")
                shutil.copy2(path, dest)
                saved.append(dest)
        QMessageBox.information(self, "Success", f"Saved {len(saved)} files.")

    # ---------- Batch callbacks ----------
    def update_batch_progress(self, msg, value):
        self.log(msg)
        self.progress_bar.setValue(value)

    def add_batch_result(self, result):
        self.batch_results.append(result)
        self.update_batch_table_row(result, "Success")

    def batch_error(self, case_name, error_msg):
        self.log(f"Error in {case_name}: {error_msg}")
        row = self.batch_table.rowCount()
        self.batch_table.insertRow(row)
        items = [case_name, "—", "—", "—", "—", "—", f"Error: {error_msg[:30]}"]
        for col, text in enumerate(items):
            item = QTableWidgetItem(text)
            item.setTextAlignment(Qt.AlignCenter)
            item.setBackground(QColor(255, 200, 200))
            self.batch_table.setItem(row, col, item)

    def batch_finished(self, all_results):
        self.log(f"Batch processing finished. Successful: {len(all_results)} cases.")
        self.batch_csv_btn.setEnabled(len(all_results) > 0)
        self.batch_excel_btn.setEnabled(len(all_results) > 0)
        self.reset_ui()

    def update_batch_table_row(self, result, status="Success"):
        row = self.batch_table.rowCount()
        self.batch_table.insertRow(row)
        items = [
            result['case'],
            f"{result['label1_HighDensity_HighEntropy_vol_mm3']:.1f}",
            f"{result['label2_HighDensity_LowEntropy_vol_mm3']:.1f}",
            f"{result['label3_LowDensity_HighEntropy_vol_mm3']:.1f}",
            f"{result['label4_LowDensity_LowEntropy_vol_mm3']:.1f}",
            "High-risk" if result['prediction'] == 1 else "Low-risk",
            status
        ]
        for col, text in enumerate(items):
            item = QTableWidgetItem(text)
            item.setTextAlignment(Qt.AlignCenter)
            # 批量表中同样高亮第2列
            if col == 2:
                if result['prediction'] == 1:
                    item.setBackground(QColor(255, 200, 200))
                else:
                    item.setBackground(QColor(200, 255, 200))
            if col == 5:  # prediction
                if result['prediction'] == 1:
                    item.setBackground(QColor(255, 200, 200))
                else:
                    item.setBackground(QColor(200, 255, 200))
            self.batch_table.setItem(row, col, item)

    # ---------- Export functions ----------
    def export_single_csv(self):
        if not self.current_results:
            return
        path, _ = QFileDialog.getSaveFileName(self, "Save CSV", "results.csv", "CSV (*.csv)")
        if path:
            df = pd.DataFrame(self.current_results)
            df.to_csv(path, index=False)
            QMessageBox.information(self, "Export Successful", f"Saved to {path}")

    def export_single_excel(self):
        if not self.current_results:
            return
        path, _ = QFileDialog.getSaveFileName(self, "Save Excel", "results.xlsx", "Excel (*.xlsx)")
        if path:
            df = pd.DataFrame(self.current_results)
            df.to_excel(path, index=False)
            QMessageBox.information(self, "Export Successful", f"Saved to {path}")

    def export_batch_csv(self):
        if not self.batch_results:
            return
        path, _ = QFileDialog.getSaveFileName(self, "Save Batch CSV", "batch_results.csv", "CSV (*.csv)")
        if path:
            df = pd.DataFrame(self.batch_results)
            df.to_csv(path, index=False)
            QMessageBox.information(self, "Export Successful", f"Saved to {path}")

    def export_batch_excel(self):
        if not self.batch_results:
            return
        path, _ = QFileDialog.getSaveFileName(self, "Save Batch Excel", "batch_results.xlsx", "Excel (*.xlsx)")
        if path:
            df = pd.DataFrame(self.batch_results)
            df.to_excel(path, index=False)
            QMessageBox.information(self, "Export Successful", f"Saved to {path}")

    def clear_single_results(self):
        self.single_table.setRowCount(0)
        self.current_results = []
        self.export_csv_btn.setEnabled(False)
        self.export_excel_btn.setEnabled(False)
        self.save_viz_btn.setEnabled(False)
        self.composite_label.clear()
        self.composite_label.setText("No composite image available")

    def clear_batch_results(self):
        self.batch_table.setRowCount(0)
        self.batch_results = []
        self.batch_csv_btn.setEnabled(False)
        self.batch_excel_btn.setEnabled(False)

    def reset_ui(self):
        self.start_btn.setEnabled(True)
        self.stop_btn.setEnabled(False)
        self.progress_bar.setValue(0)

    # ---------- Log handling ----------
    def process_log_queue(self):
        while not self.log_queue.empty():
            msg = self.log_queue.get_nowait()
            self.log_text.append(msg)
            self.log_text.ensureCursorVisible()

    def log(self, message):
        timestamp = datetime.now().strftime("%H:%M:%S")
        self.log_queue.put(f"[{timestamp}] {message}")


# ==================== Entry point ====================
def main():
    app = QApplication(sys.argv)
    app.setApplicationName("Habitat LUAD Predictor")
    window = MainWindow()
    window.show()
    sys.exit(app.exec_())

if __name__ == "__main__":
    main()
